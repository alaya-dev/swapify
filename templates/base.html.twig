<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
           <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" rel="stylesheet">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}

        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        {% block navbar %}
            {% if  not app.user%}
                {% if app.request.get('_route') == 'app_login' or  app.request.get('_route') == 'app_register'  %}
                    {% include 'layout/navBar/auth_nav.html.twig' %}
                {% else %}
                    {% include 'layout/navBar/main_nav.html.twig' %}
                {% endif %}
            {% else %}
                {% include 'layout/navBar/user_nav.html.twig' %}
            {% endif %}
        {% endblock %}
        {% block body %}{% endblock %}
        {% block footer %}
        {% if not app.request.get('_route') == 'app_login' or not app.request.get('_route') == 'app_register' %}
            {% include 'layout/footer/footer.html.twig' %}
        {% endif %}
        {% endblock %}
    </body>
</html>